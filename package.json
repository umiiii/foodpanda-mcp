{
  "name": "foodpanda-mcp",
  "version": "1.2.1",
  "description": "MCP server for ordering food from foodpanda.sg via AI assistants",
  "type": "module",
  "bin": {
    "foodpanda-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "foodpanda",
    "food-delivery",
    "ai-assistant",
    "model-context-protocol",
    "claude",
    "singapore"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/johnwhoyou/foodpanda-mcp.git"
  },
  "homepage": "https://github.com/johnwhoyou/foodpanda-mcp",
  "author": "John Carlo Joyo",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
